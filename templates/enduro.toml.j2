verbosity = "{{ enduro_debug_verbosity }}"
debug = "{{  enduro_debug_enabled }}"
debugListen = "{{ enduro_listen_debug_address }}"
{% if enduro_pipelines|length > 0 %}
useArchivematica = "true"
{% endif %}

[temporal]
namespace = "{{ enduro_temporal_namespace }}"
address = "{{ enduro_listen_temporal_address }}"
{% if enduro_pipelines|length > 0 %}
taskQueue = "global"
{% endif %}

[api]
listen = "{{ enduro_listen_api_address }}"
debug = "{{ enduro_api_debug_enabled }}"

[api.auth]
enabled = "{{ enduro_api_auth_enabled }}"

{% if enduro_api_auth_oidc|length > 0 %}
{% for api_auth_oidc in enduro_api_auth_oidc %}

[[api.auth.oidc]]
providerURL = "{{ api_auth_oidc.provider_url }}"
clientID = "{{ api_auth_oidc.client_id }}"
skipEmailVerifiedCheck = "{{ api_auth_oidc.skip_email_verified_check }}"

[api.auth.oidc.abac]
enabled = "{{ api_auth_oidc.abac_enabled }}"
claimPath = "{{ api_auth_oidc.abac_claim_path }}"
claimPathSeparator = "{{ api_auth_oidc.abac_claim_path_separator }}"
claimValuePrefix = "{{ api_auth_oidc.abac_claim_value_prefix }}"
useRoles = "{{ api_auth_oidc.abac_use_roles }}"
{% if api_auth_oidc.abac_use_roles|bool %}
rolesMapping = """
 {{ api_auth_oidc.abac_roles_mapping | replace("'",'') }}
"""
{% endif %}

{% endfor %}
{% endif %}

[api.auth.ticket.redis]
address = "redis://127.0.0.1:6379"
prefix = "enduro-ticket"

[event]
redisAddress = "redis://127.0.0.1:6379"
redisChannel = "enduro-ingest-events"

[internalapi]
listen = "{{ enduro_internal_api_listen }}"
debug = "{{enduro_internal_api_debug }}"

[internalStorage.bucket]
{% if enduro_internal_storage_url %}
url = "{{enduro_internal_storage_url }}"
{% endif %}
endpoint = "{{enduro_internal_storage_endpoint }}"
pathStyle = "{{enduro_internal_storage_pathStyle }}"
accessKey = "{{enduro_internal_storage_key }}"
secretKey = "{{enduro_internal_storage_secret }}"
region = "{{enduro_internal_storage_region }}"
bucket = "{{enduro_internal_storage_bucket }}"

{% if enduro_internal_storage_azure_account and enduro_internal_storage_azure_key %}
[internalStorage.azure]
storageAccount = "{{enduro_internal_storage_azure_account }}"
storageKey = "{{enduro_internal_storage_azure_key }}"
{% endif %}

{% if enduro_sip_sources %}
{% set sip_source = enduro_sip_sources | first %}
[sipsource]
id = "{{ sip_source.id }}"
name = "{{ sip_source.name }}"
retentionPeriod = "{{ sip_source.retention_period }}"
[sipsource.bucket]
endpoint = "{{ sip_source.endpoint }}"
pathStyle = {{ sip_source.path_style }}
accessKey = "{{ sip_source.access_key }}"
secretKey = "{{ sip_source.secret_key }}"
region = "{{ sip_source.region }}"
bucket = "{{ sip_source.bucket }}"
{% endif %}

[auditlog]
filepath = "{{ enduro_auditlog_filepath }}"
maxSize = 2147483647
compress = false

[database]
dsn = "{{ enduro_db_user }}:{{ enduro_db_pass }}@tcp({{ enduro_db_host }}:{{ enduro_db_port | int }})/{{ enduro_db_name }}"
driver = "mysql"
migrate = "true"

[storage.database]
dsn = "{{ enduro_storage_db_user }}:{{ enduro_storage_db_pass }}@tcp({{ enduro_storage_db_host }}:{{ enduro_storage_db_port | int }})/{{ enduro_storage_db_name }}"
driver = "mysql"
migrate = true

{% if enduro_child_workflows|length > 0 %}
{% for child_workflow in enduro_child_workflows %}

[[childWorkflows]]
type = "{{ child_workflow.type }}"
namespace = "{{ child_workflow.namespace }}"
taskQueue = "{{ child_workflow.taskQueue }}"
workflowName = "{{ child_workflow.workflowName }}"
{% if child_workflow.extract is defined %}
extract = "{{ child_workflow.extract }}"
{% endif %}
{% if child_workflow.sharedPath is defined %}
sharedPath = "{{ child_workflow.sharedPath }}"
{% endif %}

{% endfor %}
{% endif %}

{% if enduro_pipelines|length > 0 %}
{% for pipeline in enduro_pipelines %}

[validatePremis]
enabled = true
xsdPath = "/etc/premis.xsd"

[storage]
enduroAddress = "{{ enduro_storage_enduro_address }}"
defaultPermanentLocationId = "{{ enduro_storage_location_uuid }}"

[storage.internal]
{% if enduro_storage_internal_storage_url %}
url = "{{enduro_storage_internal_storage_url }}"
{% endif %}
endpoint = "{{enduro_storage_internal_storage_endpoint }}"
pathStyle = "{{enduro_storage_internal_storage_pathStyle }}"
key = "{{enduro_storage_internal_storage_key }}"
secret = "{{enduro_storage_internal_storage_secret }}"
region = "{{enduro_storage_internal_storage_region }}"
bucket = "{{enduro_storage_internal_storage_bucket }}"

[storage.event]
redisAddress = "redis://127.0.0.1:6379"
redisChannel = "enduro-storage-events"

[storage.aipDeletion]
approveAMSS = {{ enduro_storage_aip_deletion_approve_amss }}
reportTemplatePath = "{{ enduro_storage_aip_deletion_report_template_path }}"

[upload]
maxSize = {{ enduro_upload_max_size }}
retentionPeriod = "{{ enduro_upload_retention_period }}"

[watcher.embedded]
name = "{{ pipeline.watched_name }}"
redisAddress = "{{ pipeline.watched_redisAddress }}"
redisList = "{{ pipeline.watched_redisList }}"
endpoint = "{{ pipeline.watched_endpoint }}"
pathStyle = "{{ pipeline.watched_pathStyle }}"
key = "{{ pipeline.watched_key }}"
secret = "{{ pipeline.watched_secret }}"
region = "{{ pipeline.watched_region }}"
bucket = "{{ pipeline.watched_bucket }}"
pipeline = "{{ pipeline.name }}"
retentionPeriod = "{{ pipeline.watched_retentionPeriod }}"
stripTopLevelDir = "{{ pipeline.watched_stripTopLevelDir }}"
##rejectDuplicates = "{{ pipeline.watched_rejectDuplicates | default('false') }}"

[am]
name = "{{ pipeline.name }}"
address = "{{ pipeline.baseURL }}"
user = "{{ pipeline.user }}"
apiKey = "{{ pipeline.key }}"
#### transferDir = "{{ pipeline.transfer_dir }}"
processingConfig = "{{ pipeline.processing_config }}"
{% if pipeline.transferLocationID is defined %}
transferLocationID = "{{ pipeline.transferLocationID }}"
{% endif %}
retryDeadline = "{{ pipeline.retryDeadline }}"
pollInterval = "{{ pipeline.pollInterval | default ('10s')}}"
transferDeadline = "{{ pipeline.transferDeadline }}"
transferSourcePath = "{{ pipeline.transferSourcePath }}"

[am.sftp]
host = "{{ archivematica_fqdn_host }}"
user = "archivematica"
knownHostsFile = "/var/lib/enduro/.ssh/known_hosts"
remoteDir = "{{ pipeline.transfer_dir }}"

[preservation]
taskqueue = "am"

{% endfor %}
{% endif %}
